{
  "name": "sandercokart.com",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo start",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky",
    "clean": "turbo clean && echo 'Deleting root node_modules...' && rm -rf node_modules .next .turbo dist"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "(apps|packages)/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "(apps|packages)/*.{css,scss}": [
      "prettier --write"
    ],
    "apps/sandercokart.com/**/*.mdx": [
      "node ./scripts/article-update.js"
    ]
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.57.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "2.8.20",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "zod": "^4"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@sentry/cli",
    "@swc/core",
    "core-js-pure",
    "es5-ext",
    "esbuild",
    "msw",
    "sharp",
    "unrs-resolver"
  ],
  "volta": {
    "node": "24.14.1",
    "bun": "1.3.11"
  }
}
