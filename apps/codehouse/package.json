{
  "name": "codehouse",
  "version": "0.9.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "clean": "rm -rf node_modules .next .turbo dist",
    "i18n:check:en": "i18n-check --source en --locales messages",
    "i18n:check:nl": "i18n-check --source nl --locales messages",
    "env:use:local": "dotenvx decrypt -f .envx.local --stdout > .env",
    "env:use:prod": "dotenvx decrypt -f .envx.production --stdout > .env",
    "env:encrypt:local": "dotenvx encrypt -f .envx.local",
    "env:encrypt:prod": "dotenvx encrypt -f .envx.production"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mantine/hooks": "^8.3.17",
    "@repo/runtime-env": "workspace:*",
    "@repo/ui": "workspace:*",
    "@sentry/nextjs": "^10.43.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@uidotdev/usehooks": "^2.4.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "country-flag-icons": "1.5.18",
    "embla-carousel-react": "^8.6.0",
    "fast-glob": "^3.3.3",
    "geist": "1.3.1",
    "import-in-the-middle": "2.0.4",
    "jiti": "^2.6.1",
    "lucide-react": "^0.482.0",
    "motion": "^12.36.0",
    "next": "16.1.6",
    "next-intl": "4.6.0",
    "next-themes": "0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-error-boundary": "^4.1.2",
    "react-hook-form": "^7.71.2",
    "react-icons": "5.5.0",
    "react-remove-scroll": "^2.7.2",
    "react-simple-modal-provider": "^1.9.0",
    "require-in-the-middle": "8.0.1",
    "resend": "^4.8.0",
    "sharp": "0.33.5",
    "swiper": "^11.2.10",
    "tailwind-merge": "^3.5.0",
    "use-intl": "^4.8.3",
    "yup": "^1.7.1",
    "yup-locales": "^1.2.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lingual/i18n-check": "^0.8.19",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "4.0.14",
    "@types/node": "20.17.24",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.49.0",
    "@typescript-eslint/parser": "8.49.0",
    "autoprefixer": "10.4.21",
    "eslint": "9.22.0",
    "eslint-config-next": "16.0.10",
    "postcss": "8.5.3",
    "postcss-import": "16.1.0",
    "tailwindcss": "4.0.14",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}