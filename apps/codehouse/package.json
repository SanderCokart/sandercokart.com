{
  "name": "codehouse",
  "version": "0.9.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "clean": "rm -rf node_modules .next .turbo dist",
    "i18n:check:en": "i18n-check --source en --locales messages",
    "i18n:check:nl": "i18n-check --source nl --locales messages",
    "env:use:local": "dotenvx decrypt -f .envx.local --stdout > .env",
    "env:use:prod": "dotenvx decrypt -f .envx.production --stdout > .env",
    "env:encrypt:local": "dotenvx encrypt -f .envx.local",
    "env:encrypt:prod": "dotenvx encrypt -f .envx.production"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mantine/hooks": "^8.3.18",
    "@repo/runtime-env": "workspace:*",
    "@repo/ui": "workspace:*",
    "@sentry/nextjs": "^10.45.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "country-flag-icons": "1.6.15",
    "fast-glob": "^3.3.3",
    "geist": "1.7.0",
    "import-in-the-middle": "2.0.6",
    "jiti": "^2.6.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "next-intl": "4.8.3",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "^4.1.2",
    "react-hook-form": "^7.72.0",
    "react-icons": "5.6.0",
    "react-remove-scroll": "^2.7.2",
    "require-in-the-middle": "8.0.1",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.5.0",
    "use-intl": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lingual/i18n-check": "^0.9.3",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "20.19.37",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "autoprefixer": "10.4.27",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "postcss": "8.5.8",
    "postcss-import": "16.1.1",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}