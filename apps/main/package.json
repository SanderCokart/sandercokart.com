{
  "name": "main",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bunx --bun next dev -p 3000 -H 0.0.0.0",
    "build": "bunx --bun next build",
    "start": "bunx --bun next start -p 3000",
    "lint": "eslint",
    "article:create": "node src/scripts/create-article.js",
    "article:publish": "node src/scripts/publish-article.js",
    "clean": "rm -rf node_modules .next .turbo dist",
    "env:use:local": "dotenvx decrypt -f .envx.local --stdout > .env",
    "env:use:prod": "dotenvx decrypt -f .envx.production --stdout > .env",
    "env:encrypt:local": "dotenvx encrypt -f .envx.local",
    "env:encrypt:prod": "dotenvx encrypt -f .envx.production"
  },
  "dependencies": {
    "@next/third-parties": "16.2.1",
    "@repo/runtime-env": "workspace:*",
    "@repo/ui": "workspace:*",
    "@sentry/nextjs": "^10.45.0",
    "@shikijs/transformers": "^3.23.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "esbuild": "^0.27.4",
    "fast-glob": "^3.3.3",
    "front-matter": "^4.0.2",
    "geist": "1.7.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "import-in-the-middle": "2.0.6",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "next-mdx-remote-client": "^2.1.9",
    "next-themes": "0.4.6",
    "radix-ui": "latest",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-haiku": "^2.4.1",
    "react-icons": "5.6.0",
    "rehype-mdx-code-props": "^3.0.1",
    "remark-gfm": "^4.0.1",
    "require-in-the-middle": "8.0.1",
    "sharp": "0.34.5",
    "shiki": "^3.23.0",
    "slugify": "^1.6.8",
    "tailwind-merge": "3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "20.19.37",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/terminal-kit": "^2.5.7",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "autoprefixer": "10.4.27",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "postcss": "8.5.8",
    "postcss-import": "16.1.1",
    "tailwindcss": "4.2.2",
    "terminal-kit": "^3.1.2",
    "typescript": "5.9.3"
